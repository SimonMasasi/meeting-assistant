VITE_APP_TITLE="Meeting Assistant"

# Google OAuth "Desktop app" credentials, used by "Continue with Google".
# Create the client in Google Cloud Console → APIs & Services → Credentials
# (Application type: "Desktop app"). Google issues BOTH an ID and a secret and
# requires the secret in the token exchange even for desktop clients — set both.
# Loaded by the Rust backend at startup.
GOOGLE_CLIENT_ID="your-desktop-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-desktop-client-secret"
