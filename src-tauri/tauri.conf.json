{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [
        "target/release/libonnxruntime.1.17.1.dylib",
        "target/release/libsherpa-onnx-c-api.dylib"
      ]
    }
  },
  "productName": "Meeting Assistant",
  "mainBinaryName": "MeetingAssistant",
  "version": "0.1.0",
  "identifier": "com.meeting-assistant.app",
  "plugins": {
    "sql": {
      "preload": ["sqlite:meeting_assistant.db"]
    }
  },
  "app": {
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/meeting-assistant/**"]
        }
      }
    },
    "windows": [
      {
        "title": "tauri app",
        "width": 800,
        "height": 600,
        "useHttpsScheme": true
      }
    ]
  }
}